# MySQL 配置
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=campus_medical
MYSQL_USER=medical_user
MYSQL_PASSWORD=medical_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# MongoDB 配置
MONGO_INITDB_ROOT_USERNAME=mongo_user
MONGO_INITDB_ROOT_PASSWORD=mongo_password
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DATABASE=campus_medical
MONGO_APP_USER=medical_app
MONGO_APP_PASSWORD=medical_app_password

# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_SPRING_PORT=8080
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
APP_TIMEZONE=Asia/Shanghai
SETTINGS_ENCRYPTION_KEY=replace-with-fernet-key
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3100","http://127.0.0.1:3100","http://frontend:3000","http://frontend-spring:3000"]

# 前端配置
FRONTEND_PORT=3000
FRONTEND_SPRING_PORT=3100
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_AGENT_API_BASE_URL=http://localhost:8001/api/v1

# Docker
COMPOSE_PROJECT_NAME=campus-medical

# Amazon Scraper (do not commit cookies/session)
AMAZON_ASIN=B0FMNJTVH1
AMAZON_BASE_URL=https://www.amazon.co.jp
AMAZON_FETCH_BACKEND=playwright
# Put cookie export JSON here (recommended) OR Playwright storage_state JSON.
AMAZON_COOKIES_FILE=/home/user/workspace/amazon_cookies.json
AMAZON_STORAGE_STATE_FILE=
AMAZON_MAX_PAGES=3
AMAZON_DELAY_MIN_SEC=5
AMAZON_DELAY_MAX_SEC=12
AMAZON_LONG_PAUSE_EVERY=10
AMAZON_LONG_PAUSE_MIN_SEC=25
AMAZON_LONG_PAUSE_MAX_SEC=55
